---
import DetailView from '../../components/DetailView.astro';
import reviewsRaw from '../../data/reviews.json';
import reviewsKoRaw from '../../data/reviews_ko.json';

export async function getStaticPaths() {
  const reviews: any[] = reviewsRaw;
  return reviews.map((_: any, i: number) => ({ params: { id: String(i) } }));
}

const { id } = Astro.params;

const reviews: any[] = reviewsRaw;
const reviewsKo: any[] = reviewsKoRaw;

const item = reviews[Number(id)];
const koMap = Object.fromEntries(reviewsKo.map((r: any) => [r.url, r]));
const ko = item ? koMap[item.url] : null;
const date: string | null = item?.date ?? null;
---

<DetailView
  item={item}
  ko={ko}
  date={date}
  backTab="reviews"
  backLabel="PR Reviews 목록"
  typeLabel="Bitcoin Core PR Review"
/>
