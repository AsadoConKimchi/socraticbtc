---
export interface Props {
  title: string;
  translatedTitle?: string;
  url: string;
  date?: string;
  isTranslated: boolean;
  href: string;
}
const { title, translatedTitle, url, date, isTranslated, href } = Astro.props;
const displayTitle = isTranslated && translatedTitle ? translatedTitle : title;
---

<a href={href} class="block group">
  <div class="bg-surface border border-border rounded-lg p-5 hover:border-btc/60 transition-all duration-200 hover:shadow-lg hover:shadow-btc/5">
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="text-base font-medium text-gray-100 group-hover:text-btc transition-colors leading-snug line-clamp-2">
        {displayTitle}
      </h3>
      <span class={`shrink-0 text-xs px-2 py-0.5 rounded-full font-medium ${
        isTranslated
          ? 'bg-btc/10 text-btc border border-btc/20'
          : 'bg-gray-700/50 text-gray-400 border border-gray-600/30'
      }`}>
        {isTranslated ? '🤖 LLM 번역' : '원문 (영어)'}
      </span>
    </div>
    {date && (
      <p class="text-xs text-gray-500 mt-1">{date}</p>
    )}
    {isTranslated && translatedTitle !== title && (
      <p class="text-xs text-gray-500 mt-2 truncate">원문: {title}</p>
    )}
  </div>
</a>
